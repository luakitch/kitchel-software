# App Store Server Notifications (required for verification)
APP_STORE_BUNDLE_ID=com.example.app
# Numeric App Store Connect app ID (App Information). Required for production notifications.
APP_STORE_APP_APPLE_ID=1234567890

# Optional: require ?token=... or Authorization: Bearer ... on webhook requests
# APP_STORE_WEBHOOK_SECRET=

# Optional: enable OCSP / expiry checks (can fail or slow cold starts on some hosts)
# APPLE_CERT_ONLINE_CHECKS=true

# ntfy — set topic URL to receive phone pushes (omit to verify-only / logging)
# NTFY_TOPIC_URL=https://ntfy.sh/your-secret-topic
# NTFY_ACCESS_TOKEN=
